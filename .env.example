# SecureVault Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme_strong_password_here
DB_SUPERUSER_PASSWORD=changeme_superuser_password_here

# ─────────────────────────────────────────────────────────────────────────────
# Key file paths (must point to Docker secrets or secure volume mounts)
# ─────────────────────────────────────────────────────────────────────────────
MEK_FILE_PATH=./secrets/securevault-mek
JWT_KEY_PATH=./secrets/jwt-signing.pem

# ─────────────────────────────────────────────────────────────────────────────
# TLS
# ─────────────────────────────────────────────────────────────────────────────
TLS_CERT_PATH=./nginx/certs

# ─────────────────────────────────────────────────────────────────────────────
# Authentication mode
# ─────────────────────────────────────────────────────────────────────────────
AUTH_MODE=local  # Options: local, ldap

# ─────────────────────────────────────────────────────────────────────────────
# Optional: LDAP configuration (only needed if AUTH_MODE=ldap)
# ─────────────────────────────────────────────────────────────────────────────
# LDAP_HOST=ldap.example.com
# LDAP_BASE_DN=dc=example,dc=com

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Syslog forwarding
# ─────────────────────────────────────────────────────────────────────────────
SYSLOG_HOST=
# SYSLOG_USE_TLS=true   # default true; set false only for plaintext-only syslog servers
                        # on a fully isolated private network segment (default port changes to 514)
