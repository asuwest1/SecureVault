{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=securevault;Username=securevault_app;Password=${DB_PASSWORD}"
  },
  "Encryption": {
    "KeyFilePath": "/run/secrets/securevault-mek"
  },
  "Auth": {
    "Mode": "local",
    "JwtIssuer": "SecureVault",
    "JwtAudience": "SecureVault",
    "JwtSigningKeyPath": "/run/secrets/jwt-signing.pem",
    "Ldap": {
      "Host": "",
      "Port": 636,
      "BaseDn": "",
      "UserDnTemplate": "uid={0},{baseDn}",
      "EmailAttribute": "mail",
      "DisplayNameAttribute": "displayName"
    }
  },
  "Syslog": {
    "Host": "",
    "Port": 514
  },
  "Logging": {
    "AuditRetentionDays": 365,
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": ["https://yourdomain.example.com"]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/auth/mfa/verify",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "*:/api/*",
        "Period": "1m",
        "Limit": 300
      }
    ]
  },
  "AllowedHosts": "*"
}
